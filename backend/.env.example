# Backend Environment Variables

# Server Port
PORT=5000

# Frontend URL for CORS
FRONTEND_URL=http://localhost:5173

# MongoDB Connection String
# For local MongoDB: mongodb://localhost:27017/aicodeexplainer
# For MongoDB Atlas: mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/aicodeexplainer
MONGO_URI=mongodb://localhost:27017/aicodeexplainer

# Google Gemini AI API Key
GEMINI_API_KEY=your_gemini_api_key_here